@startuml Database_Architecture
!theme plain
title EduDesk - Database Schema & Data Flow Architecture

skinparam backgroundColor #E2E8EF
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #496E96
skinparam classArrowColor #2D2F31
skinparam activityBackgroundColor #496E96

package "SQLite / PostgreSQL (Supabase)" {
    
    entity "Users" as users {
        **PK** id : UUID
        --
        name : String (NOT NULL)
        nim : String (UNIQUE)
        email : String (UNIQUE, NOT NULL)
        password_hash : String (bcrypt-hashed)
        role : Enum (STUDENT|INSTRUCTOR|ADMIN)
        phone : String (Optional)
        address : String (Optional)
        profile_picture : String (URL, Optional)
        status : Enum (ACTIVE|INACTIVE|SUSPENDED)
        created_at : Timestamp
        updated_at : Timestamp
        last_login : Timestamp (Optional)
    }
    
    entity "Courses" as courses {
        **PK** id : UUID
        --
        **FK** instructor_id : UUID → users.id
        name : String (NOT NULL)
        code : String (UNIQUE, NOT NULL)
        description : Text
        capacity : Integer (max students)
        status : Enum (PENDING|ACTIVE|ARCHIVED|REJECTED)
        rejection_reason : Text (Optional)
        syllabus : Text (Optional)
        credits : Integer
        semester : String
        start_date : Date
        end_date : Date
        created_at : Timestamp
        updated_at : Timestamp
    }
    
    entity "Enrollments" as enrollments {
        **PK** id : UUID
        --
        **FK** user_id : UUID → users.id
        **FK** course_id : UUID → courses.id
        enrolled_at : Timestamp
        status : Enum (ACTIVE|COMPLETED|WITHDRAWN)
        grade : Decimal(3,1) (Optional)
        completion_percent : Integer (0-100, Optional)
        UNIQUE(user_id, course_id)
    }
    
    entity "Assignments" as assignments {
        **PK** id : UUID
        --
        **FK** course_id : UUID → courses.id
        **FK** user_id : UUID → users.id
        title : String (NOT NULL)
        description : Text
        assignment_type : Enum (HOMEWORK|PROJECT|QUIZ|EXAM)
        points : Integer (total possible)
        deadline : Timestamp
        status : Enum (PENDING|SUBMITTED|GRADED|OVERDUE)
        created_at : Timestamp
        updated_at : Timestamp
    }
    
    entity "Submissions" as submissions {
        **PK** id : UUID
        --
        **FK** assignment_id : UUID → assignments.id
        **FK** user_id : UUID → users.id
        file_path : String (storage location)
        submitted_at : Timestamp
        grade : Decimal(3,1) (Optional)
        feedback : Text (Instructor comments)
        graded_date : Timestamp (Optional)
        status : Enum (SUBMITTED|GRADED|LATE)
    }
    
    entity "Lessons" as lessons {
        **PK** id : UUID
        --
        **FK** course_id : UUID → courses.id
        title : String (NOT NULL)
        description : Text
        content : Text (lesson material)
        content_type : Enum (VIDEO|PDF|TEXT|INTERACTIVE)
        sequence : Integer (order in course)
        duration_minutes : Integer (Optional)
        created_at : Timestamp
    }
    
    entity "Materials" as materials {
        **PK** id : UUID
        --
        **FK** course_id : UUID → courses.id
        file_name : String
        file_path : String (storage location)
        file_size_mb : Decimal
        upload_date : Timestamp
        uploaded_by : UUID (FK → users.id)
        material_type : Enum (SYLLABUS|TEXTBOOK|REFERENCE|EXAMPLE)
    }
    
    entity "UserProgress" as progress {
        **PK** id : UUID
        --
        **FK** user_id : UUID → users.id
        **FK** course_id : UUID → courses.id
        lessons_completed : Integer
        total_lessons : Integer
        completion_percent : Integer (0-100)
        time_spent_hours : Decimal
        last_activity : Timestamp
        UNIQUE(user_id, course_id)
    }
    
    entity "Messages" as messages {
        **PK** id : UUID
        --
        **FK** sender_id : UUID → users.id
        **FK** recipient_id : UUID → users.id
        subject : String
        body : Text
        sent_at : Timestamp
        read_at : Timestamp (Optional)
        archived : Boolean (default FALSE)
    }
    
    entity "AuditLog" as audit {
        **PK** id : UUID
        --
        **FK** user_id : UUID → users.id
        timestamp : Timestamp
        action : String (CREATE|UPDATE|DELETE|LOGIN|LOGOUT)
        resource_type : String (User|Course|Assignment, etc.)
        resource_id : UUID
        old_value : JSON (Optional)
        new_value : JSON (Optional)
        ip_address : String (Optional)
    }
    
    entity "Sessions" as sessions {
        **PK** id : UUID
        --
        **FK** user_id : UUID → users.id
        token : String (JWT or session token)
        created_at : Timestamp
        expires_at : Timestamp
        active : Boolean
        device_info : String (Optional)
    }
}

package "In-Memory SessionManager" {
    entity "SessionState" as session_state {
        **current_user** : User
        **is_authenticated** : Boolean
        **user_role** : Enum (STUDENT|INSTRUCTOR|ADMIN)
        **last_action_time** : Timestamp
        **sync_status** : Enum (LOCAL|SYNCED|PENDING)
    }
}

package "Data Flow & Service Interactions" {
    note "Authentication Flow" as auth_note
    note "Service Calls → DB Operations → Session Update → UI Recompose" as flow_note
}

