@startuml EduDesk_Activity_Diagram
!theme plain
title EduDesk LMS - Comprehensive Activity Diagram

skinparam ActivityBackgroundColor #496E96
skinparam ActivityBorderColor #2D2F31
skinparam ActivityFontColor #FFFFFF
skinparam PartitionBackgroundColor #E2E8EF
skinparam PartitionBorderColor #2D2F31
skinparam PartitionFontColor #2D2F31

partition "System Initialization" {
    :🚀 Application Startup;
    :initialize Main.kt - Create 1280x800 Window;
    :call DatabaseSetup.init();
    :Connect to SQLite (edudesk.db);
    :Create Database Schema if needed;
    :Seed 4 Default Test Users;
    if (Supabase Configuration Available?) then (Yes)
        :Initialize Supabase Client;
        :Configure REST API endpoint;
    else (No)
        :📱 Offline Mode - SQLite Only;
    endif
    :NavController routes to LoginScreen;
}

partition "Authentication & Session Management" {
    :👤 User arrives at LoginScreen;
    :Display Email/NIM + Password input fields;
    :User enters credentials;
    
    while (Authentication Loop) is (Continue)
        :Extract email/NIM and password;
        :call AuthService.login(nim, password);
        
        if (Query SQLite Users Table) then (Match Found)
            :Verify BCrypt password hash;
            if (Password Hash Valid?) then (✅ Correct)
                :✅ Authentication Successful;
                :call SessionManager.setLocalUser(User);
                :Store current user in memory;
                if (Supabase enabled?) then (Yes)
                    :⇆ Sync user data with Supabase;
                else (No)
                    :Continue with local session;
                endif
                break
            else (❌ Incorrect)
                :❌ Show "Invalid Password" error;
                :remain on LoginScreen;
            endif
        else (No Match)
            :❌ Show "User not found" error;
            :remain on LoginScreen;
        endif
    endwhile
    
    :✅ Session established;
}

partition "Role-Based Dashboard Routing" {
    if (Check User Role?) then (STUDENT)
        :route to HomeScreen;
    elseif (INSTRUCTOR)
        :route to InstructorDashboard;
    else (ADMIN)
        :route to AdminDashboard;
    endif
}

partition "STUDENT WORKFLOW" {
    note left : Role = STUDENT\nAccess Level: User content only
    
    :📚 Student HomeScreen displayed;
    :Show quick access to 3 enrolled courses;
    :Display upcoming assignments (deadline-sorted);
    
    partition "Student Path A: Course Enrollment" {
        :📖 User clicks "Browse All Courses";
        :route to CourseRegistrationScreen;
        :Display course catalog (search + filter);
        :User types search query or browses categories;
        :call CourseService.searchCourses(query);
        :PostgreSQL/SQLite returns filtered results;
        
        while (Course Selection Loop) is (Continue)
            :Display matching courses with cards;
            :User clicks on a course card;
            
            :route to CourseDetailScreen;
            :Fetch course details (syllabus, duration);
            :Display instructor info and prerequisites;
            :Show "Enroll" button;
            
            if (User clicks Enroll?) then (Yes)
                :call CourseService.addCourse(courseId);
                :INSERT into Enrollments table;
                :INSERT into UserCourses mapping;
                :✅ Enrollment confirmed;
                :Show success notification;
                if (Continue browsing?) then (Yes)
                    :Back to CourseRegistrationScreen;
                else (No)
                    break
                endif
            else (No - Back)
                :Back to CourseRegistrationScreen;
            endif
        endwhile
        
        :route to MyLearningScreen;
        :Display all enrolled courses;
        :Show progress indicators (% complete);
    }
    
    partition "Student Path B: Assignments & Submission" {
        :📝 User clicks "Assignments";
        :route to AssignmentsScreen;
        :call AssignmentService.getAssignmentsForUser();
        :Fetch all assignments with status (pending/done);
        :Sort by deadline (nearest first);
        :Display assignment list with cards;
        
        while (Assignment Management) is (Continue)
            :User clicks on assignment;
            :Display assignment details:
            :  - Title, description, deadline;
            :  - Points, submission status;
            :  - File attachments, rubric;
            
            if (User ready to submit?) then (Yes)
                :Upload submission file or enter text;
                :call AssignmentService.submitAssignment();
                :INSERT submission into database;
                :call AssignmentService.markDone();
                :UPDATE assignment status to DONE;
                :✅ Submission confirmed;
                :Show confirmation with timestamp;
                if (View another assignment?) then (Yes)
                    :Back to AssignmentsScreen;
                else (No)
                    break
                endif
            else (No - View Only)
                :Back to AssignmentsScreen;
            endif
        endwhile
    }
    
    partition "Student Path C: Learning Content" {
        :🎓 User clicks "Lessons";
        :call CourseService.getLessonsForCourse(courseId);
        :route to LessonScreen;
        :Display lesson modules in sequence;
        :User watches videos or reads materials;
        :Mark lesson as completed;
        :Track progress % in real-time;
    }
}

partition "INSTRUCTOR WORKFLOW" {
    note left : Role = INSTRUCTOR\nAccess Level: Own courses + student management
    
    :👨‍🏫 Instructor InstructorDashboard displayed;
    :Display statistics: 37 classes, 236 students;
    
    partition "Instructor Path A: Class Management" {
        :🏫 User clicks "My Classes";
        :Display list of owned courses;
        :Show enrollment count, status (active/archived);
        
        while (Class Management) is (Continue)
            if (Action type?) then (Create New)
                :route to CourseCreationForm;
                :call CourseService.addCourse();
                :INSERT into Courses table;
                :✅ Course created;
            elseif (Edit)
                :route to CourseEditForm;
                :call CourseService.updateCourse();
                :UPDATE Courses table;
                :✅ Changes saved;
            elseif (Delete)
                :Confirm deletion;
                :call CourseService.deleteCourse();
                :DELETE from Courses table;
                :✅ Course removed;
            else (View Details)
                :Display students enrolled in course;
                :Show submission statistics;
            endif
            
            if (Continue managing?) then (Yes)
                :Back to class list;
            else (No)
                break
            endif
        endwhile
    }
    
    partition "Instructor Path B: Material Upload" {
        :📤 User clicks "Upload Materials";
        :Select course to upload to;
        :Choose file (PDF, Video, Presentation);
        :call CourseService.uploadMaterial(file);
        :Store in file system or cloud storage;
        :✅ Material available to students;
    }
    
    partition "Instructor Path C: Grading" {
        :✅ User clicks "Grade Submissions";
        :call AssignmentService.getSubmissions();
        :Display list of submitted assignments;
        :Filter by course and due date;
        
        while (Grading Loop) is (Continue)
            :Click on student submission;
            :View uploaded file or text;
            :Review submission against rubric;
            :Enter grade score;
            :Optional: Add feedback comments;
            :call AssignmentService.gradeSubmission();
            :UPDATE grade in database;
            :✅ Grade recorded;
            :Send notification to student;
            
            if (Grade next submission?) then (Yes)
                :Move to next student;
            else (No)
                break
            endif
        endwhile
    }
}

partition "ADMIN WORKFLOW" {
    note left : Role = ADMIN\nAccess Level: All system data
    
    :⚙️ Admin AdminDashboard displayed;
    :Display system statistics;
    :  - Total users: 1,245;
    :  - Active courses: 86;
    :  - Total enrollments: 3,421;
    
    partition "Admin Path A: System Statistics" {
        :pull System Analytics;
        :Generate reports (CSV/PDF);
        :Review enrollment trends;
        :Analyze course popularity;
    }
    
    partition "Admin Path B: User Management" {
        :👥 User clicks "User Management";
        :Fetch all users from database;
        :Display user table:
        :  - Name, NIM, Email, Role;
        :  - Status (active/inactive/suspended);
        :  - Enrollment count;
        
        while (User Admin Loop) is (Continue)
            if (Admin Action?) then (View Profile)
                :Display user details;
                :Show enrollment history;
            elseif (Change Status)
                :Toggle active/inactive;
                :UPDATE Users.status column;
                :✅ Status changed;
                if (Send notification?) then (Yes)
                    :notify user of status change;
                endif
            elseif (Reset Password)
                :Generate temporary password;
                :Send via email;
                :USER must change on next login;
            elseif (Delete User)
                :Confirm deletion;
                :CASCADE delete related records;
                :DELETE from Users table;
            endif
            
            if (Manage another user?) then (Yes)
                :Back to User Management;
            else (No)
                break
            endif
        endwhile
    }
    
    partition "Admin Path C: Course Approvals" {
        :📋 Click "Pending Course Approvals";
        :Fetch courses with status = PENDING;
        :Display course review queue;
        
        while (Approval Loop) is (Continue)
            :Review course details:
            :  - Title, code, description;
            :  - Instructor name, prerequisites;
            :  - Student capacity, syllabus;
            
            if (Approve course?) then (✅ Approve)
                :UPDATE course status to ACTIVE;
                :notify instructor of approval;
                :Course available to students;
            elseif (❌ Reject)
                :Request revisions from instructor;
                :Add rejection notes to database;
                :notify instructor to resubmit;
            else (📌 Review Later)
                :Status remains PENDING;
            endif
            
            if (Review next course?) then (Yes)
                :Back to approval queue;
            else (No)
                break
            endif
        endwhile
    }
    
    partition "Admin Path D: System Configuration" {
        :⚙️ User clicks "Settings";
        :Display system configuration options:
        :  - Supabase API key management;
        :  - Database backup scheduling;
        :  - User role templates;
        :  - Email notification settings;
        :Make configuration changes;
        :✅ Save to configuration file;
    }
}

partition "Common Features (All Roles)" {
    :👤 User clicks "Profile";
    :route to ProfileScreen;
    :call UserService.getUserProfile();
    :Display user information:
    :  - Name, NIM, Email, Role;
    :  - Phone, Address (if provided);
    :  - Profile picture;
    
    if (Edit profile?) then (Yes)
        :Modify profile fields;
        :call UserService.updateProfile();
        :UPDATE Users table;
        :✅ Profile updated;
    endif
    
    :navigate to AccountSettingsScreen;
    :Display account settings:
    :  - Change password;
    :  - Email preferences;
    :  - Notifications on/off;
    :  - Theme (Light/Dark);
    
    :navigate to HelpScreen;
    :Display FAQs and documentation;
    :Contact support form;
    
    :📞 navigate to MessagesScreen;
    :Display message inbox;
    :Send/receive messages with other users;
    
    :🚪 User clicks "Logout";
    :call SessionManager.clearSession();
    :Clear user from memory;
    :route back to LoginScreen;
    :✅ Session terminated;
}

partition "Error Handling & Exceptions" {
    note right : All operations wrapped in try-catch blocks
    
    if (Network Error?) then (Database connection failed)
        :❌ Show "Database unavailable" error;
        :Retry connection (max 3 attempts);
    elseif (Validation Error?)
        :❌ Display field validation errors;
        :Highlight invalid input;
        :Suggest corrections;
    elseif (Permission Error?)
        :❌ Show "Access denied" message;
        :Log unauthorized attempt;
    elseif (File Upload Error?)
        :❌ Show upload failure reason;
        :User retries or cancels;
    else (Unexpected Error)
        :❌ Log to error tracking system;
        :Show generic error message;
        :Direct user to help/support;
    endif
}

end

@enduml
