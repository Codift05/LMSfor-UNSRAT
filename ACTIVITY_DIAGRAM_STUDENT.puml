@startuml Student_Workflow
!theme plain
title Iels - Student Learning Workflow (Course → Assignment → Submission)

skinparam ActivityBackgroundColor #2196F3
skinparam ActivityBorderColor #0D47A1
skinparam ActivityFontColor #FFFFFF
skinparam DecisionBackgroundColor #1976D2
skinparam DecisionBorderColor #0D47A1
skinparam DecisionFontColor #FFFFFF

participant Student
participant "HomeScreen\n(UI)" as Home
participant "CourseService\n(Business Logic)" as CS
participant "AssignmentService" as AS
participant "SQLite/Supabase\n(Database)" as DB
participant "SessionManager\n(Auth)" as Session

activate Home

Home -> Session: 1. Retrieve current student
activate Session
Session -->> Home: Return Student object
deactivate Session

Home -> Home: 2. Display HomeScreen\n- Quick access to 3 enrolled courses\n- Upcoming assignments (deadline-sorted)\n- Learning progress indicators

loop Student Activities
    Student -> Home: 3. Choose action
    
    alt 📖 Browse & Enroll Courses
        Home -> CS: 4. searchCourses(query)
        activate CS
        CS -> DB: SELECT * FROM Courses\nWHERE name LIKE ? OR description LIKE ?
        activate DB
        DB -->> CS: Return course list
        deactivate DB
        
        CS -> Home: Display course cards\n[Course name, code, instructor, capacity]
        deactivate CS
        
        loop Browse Courses
            Student -> Home: 5. Click course card
            
            Home -> CS: 6. getCourseDetails(courseId)
            activate CS
            CS -> DB: SELECT * FROM Courses WHERE id = ?
            activate DB
            DB -->> CS: Return course object + syllabus
            deactivate DB
            
            CS -> Home: Display CourseDetailScreen\n[Full syllabus, prerequisites, enrollment status]
            deactivate CS
            
            alt Enroll This Course?
                Student -> Home: 7. Click "Enroll" button
                
                Home -> CS: 8. addCourse(courseId)
                activate CS
                
                CS -> DB: BEGIN TRANSACTION
                activate DB
                
                CS -> DB: INSERT INTO Enrollments\n(user_id, course_id, enrolled_at)
                CS -> DB: INSERT INTO UserCourses\n(user_id, course_id)
                
                alt Success
                    DB -->> CS: Return success
                    CS -> CS: Update cache in memory
                else Duplicate Enrollment
                    DB -->> CS: Return error\n"Already enrolled"
                    CS -->> Home: Show error toast
                end
                
                DB -> DB: COMMIT TRANSACTION
                deactivate DB
                
                Home -> CS: Refresh course list
                deactivate CS
                Home -> Home: Update MyLearningScreen
                Home -> Student: ✅ Enrollment confirmed
            else Back to Browse
                Home -> Home: Back to course list
            end
        end
        
    else (2) 📝 View & Submit Assignments
        Home -> AS: 9. getAssignmentsForUser()
        activate AS
        AS -> DB: SELECT * FROM Assignments\nWHERE user_id = ? ORDER BY deadline ASC
        activate DB
        DB -->> AS: Return assignment list
        deactivate DB
        
        AS -> AS: Sort by deadline (nearest first)\nFilter status (pending/done/overdue)
        
        AS -> Home: Display AssignmentsScreen\n[List of assignments with status badges]
        deactivate AS
        
        loop Management Loop
            Student -> Home: 10. Select assignment
            
            Home -> AS: 11. getAssignmentDetails(assignmentId)
            activate AS
            AS -> DB: SELECT * FROM Assignments WHERE id = ?
            activate DB
            DB -->> AS: Return assignment object + metadata
            deactivate DB
            
            AS -> Home: Display assignment details\n- Title, description, rubric\n- Points, deadline, submission file\n- Current status (pending/submitted/graded)
            deactivate AS
            
            alt Submit Assignment
                Student -> Home: 12. Upload work file or enter text
                Home -> Home: Validate file type & size
                
                Home -> AS: 13. submitAssignment(fileData)
                activate AS
                
                AS -> DB: BEGIN TRANSACTION
                activate DB
                AS -> DB: INSERT INTO Submissions\n(assignment_id, user_id, file_path, submitted_at)
                
                alt File stored successfully
                    DB -->> AS: Return submission_id
                    
                    AS -> DB: UPDATE Assignments SET status = 'DONE'\nWHERE id = ?
                    
                    AS -> AS: Create submission record
                    DB -->> AS: Confirm delete
                else Upload failed
                    DB -->> AS: Return error\n"File upload failed"
                end
                
                DB -> DB: COMMIT TRANSACTION
                deactivate DB
                
                AS -> Home: ✅ Submission confirmed\n[Show timestamp + 'Submitted Successfully']
                deactivate AS
                
                Home -> Student: Display success notification\nwith submission timestamp
                
            else View Only
                Home -> Student: Display submission deadline & status
            end
        end
        
    else (3) 🎓 Learn Lessons
        Home -> CS: 14. getLessonsForCourse(courseId)
        activate CS
        CS -> DB: SELECT * FROM Lessons\nWHERE course_id = ? ORDER BY sequence ASC
        activate DB
        DB -->> CS: Return lesson list
        deactivate DB
        
        CS -> Home: Display LessonScreen\n[Lesson modules in sequence]
        deactivate CS
        
        loop Consume Content
            Student -> Home: 15. Click lesson
            
            Home -> Home: Display lesson content\n[Video player, PDF viewer, Q&A]\n[Timer, progress indicator]
            
            Student -> Home: 16. View/Watch content
            
            Home -> Home: 17. Complete lesson timeline
            
            Home -> AS: 18. markLessonComplete(lessonId)
            activate AS
            AS -> DB: UPDATE Lessons SET completed = TRUE\nWHERE id = ? AND user_id = ?
            activate DB
            DB -->> AS: Success
            deactivate DB
            
            AS -> AS: Recalculate course progress %\n(lessons_completed / total_lessons)
            AS -> Home: Update progress indicator
            deactivate AS
        end
        
    else (4) 📊 View My Learning Progress
        Home -> CS: 19. getMyLearningProgress()
        activate CS
        CS -> DB: SELECT course_id, completion_percent, grade\nFROM UserCourses WHERE user_id = ?
        activate DB
        DB -->> CS: Return progress data
        deactivate DB
        
        CS -> Home: Display MyLearningScreen\n[All courses + progress bars]\n[Grade (if available)]
        deactivate CS
        
        Student -> Home: Review progress tracking
    end
end

Home -> Home: 20. Data persisted & synced
Home -> Home: If Supabase enabled → Auto-sync\nelse: SQLite local only

deactivate Home

note right of Student, Home
    **Student Learning Paths:**
    1. Course Enrollment: Browse → View Details → Enroll
    2. Assignment Submission: View → Understand → Upload → Track
    3. Lesson Consumption: Watch → Complete → Progress Update
    4. Progress Tracking: View all courses → Check grades → Review timeline
    
    **Database Flow:**
    - Enrollments table: tracks user-course relationships
    - Assignments table: stores assignment metadata + status
    - Submissions table: stores student work files + timestamps
    - Lessons table: lesson content + completion tracking
    - UserCourses: progress % and final grades
    
    **Error Handling:**
    - Invalid file type → Show error toast
    - Duplicate enrollment → Prevent re-enrollment
    - Assignment overdue → Show warning, allow submission
    - Network failure → Queue for later sync
end note

@enduml
